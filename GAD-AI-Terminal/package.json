{
  "name": "gad-ai-terminal",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "services/*",
    "libs/*"
  ],
  "scripts": {
    "build": "npm run build:api && npm run build:scanner && npm run build:telegram && npm run build:autobuy && npm run build:whale-tracker && npm run build:dashboard && npm run build:landing",
    "build:api": "npm --workspace services/api run build",
    "build:scanner": "npm --workspace services/scanner run build",
    "build:telegram": "npm --workspace services/telegram run build",
    "build:autobuy": "npm --workspace services/autobuy run build",
    "build:whale-tracker": "npm --workspace services/whale-tracker run build",
    "build:dashboard": "npm --workspace services/dashboard run build",
    "build:landing": "npm --workspace services/landing run build",
    "start:api": "npm --workspace services/api run start",
    "start:scanner": "npm --workspace services/scanner run start",
    "start:telegram": "npm --workspace services/telegram run start",
    "start:autobuy": "npm --workspace services/autobuy run start",
    "start:dashboard": "npm --workspace services/dashboard run dev",
    "start:landing": "npm --workspace services/landing run dev",
    "test": "npm --workspace services/api run test && npm --workspace services/scanner run test"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.19",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.14.4",
    "@types/node-fetch": "^2.6.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.6",
    "body-parser": "^1.20.3",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.4.5",
    "next": "14.2.3",
    "node-telegram-bot-api": "^0.61.0",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
