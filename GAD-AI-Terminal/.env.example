# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=gad
POSTGRES_PASSWORD=gadpass
POSTGRES_DB=gad_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=
# Treasury wallet address that receives SOL payments
TREASURY_WALLET_ADDRESS=


# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─── App URLs ─────────────────────────────────────────────────────────────────
API_BASE_URL=http://api:4000
DASHBOARD_BASE_URL=http://localhost:3000










# ─── Auth service (JWT) ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
DATABASE_URL=postgresql://gad:gadpass@postgres:5432/gad_ai

# ─── Payments service (Stripe) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_EU=price_eu_pro
STRIPE_PRICE_US=price_us_pro
WEB_URL=https://gadai.shop

# ─── Owner / Free Wallets ─────────────────────────────────────────────────────
# Comma-separated Solana wallet addresses that bypass subscription checks
# Use this for your own wallets to test without payment
FREE_WALLETS=

# ─── Autobuy / Autosell trading config ────────────────────────────────────────
# Private key of trading wallet (JSON array format or base58)
WALLET_PRIVATE_KEY=

# How often the autobuy scheduler polls for due jobs (seconds)
AUTOBUY_POLL_SECONDS=15

# Auto-disable a job after this many consecutive errors
AUTOBUY_MAX_ERRORS=5

# Slippage tolerance for buys (100 = 1%)
AUTOBUY_SLIPPAGE_BPS=100

# Slippage tolerance for autosell stages (150 = 1.5%)
AUTOSELL_SLIPPAGE_BPS=150

# Stop-loss: sell all if price drops this % below entry (50 = -50%). 0 = disabled.
STOP_LOSS_PCT=50

# ─── Autonomous trading (auto-signal) ─────────────────────────────────────────
# Master switch — set to 'true' to enable fully autonomous trading
AUTO_BUY_ENABLED=false

# Max concurrent open auto-trade positions
MAX_AUTO_POSITIONS=3

# SOL amount per auto-triggered trade
AUTO_BUY_SOL=0.02

# Max total SOL spent per 24 hours across all auto-trades
DAILY_MAX_SOL=0.2

# Minimum alert score to trigger auto-buy (0-100)
MIN_SIGNAL_SCORE=90

# Don't re-buy the same token within this many hours
SIGNAL_COOLDOWN_HOURS=6
